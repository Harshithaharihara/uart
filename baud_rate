module baud_gen #(parameter CLOCK_FREQ = 50000000,
                  parameter BAUD_RATE  = 9600)
(
    input clk,
    input rst,
    output reg tick
);
    localparam integer BAUD_DIV = CLOCK_FREQ / BAUD_RATE;
    integer count;
    always @(posedge clk or posedge rst)
    begin
        if(rst)
        begin
            count <= 0;
            tick <= 0;
        end
        else
        begin
            if(count == BAUD_DIV-1)
            begin
                count <= 0;
                tick <= 1;
            end
            else
            begin
                count <= count + 1;
                tick <= 0;
            end
        end
    end
endmodule
